rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: ist der eingeloggte User ein freigeschalteter Mitarbeiter?
    // Wird benötigt seit anonyme Besucher (Sekretariat-Chat-Widget) sich
    // ebenfalls bei Firebase Auth anmelden — die dürfen NICHT auf andere
    // Collections zugreifen.
    function isStaff() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('locked', false) != true;
    }

    // Helper: ist der eingeloggte User ein approved Admin?
    // Wird für Privilege-kritische Schreiboperationen auf `users/{uid}` genutzt,
    // damit normale Mitarbeiter sich nicht selbst zu Admin upgraden können.
    function isAdmin() {
      return isStaff()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // passwordResetRequests: jeder darf erstellen (ohne Login), nur Staff liest/ändert
    match /passwordResetRequests/{id} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }

    // adminMessages: unauthentifizierte Benutzer dürfen erstellen (Login-Seite Kontaktformular)
    match /adminMessages/{id} {
      allow create: if
        request.resource.data.keys().hasOnly(['topic', 'senderName', 'email', 'note', 'status', 'createdAt']) &&
        request.resource.data.topic in ['login', 'other'] &&
        request.resource.data.status == 'pending' &&
        (request.resource.data.senderName is string && request.resource.data.senderName.size() <= 100) &&
        (request.resource.data.note is string && request.resource.data.note.size() <= 500);
      allow read, update, delete: if isStaff();
    }

    // users: lesbar ohne Login (für Username→Email-Lookup beim Login & Passwort-Reset).
    //
    // Schreibrechte sind streng abgestuft, damit normale Mitarbeiter sich
    // NICHT selbst zu Admin upgraden oder die Status-/Rollen-/Permissions-
    // Felder anderer User manipulieren können:
    //
    //  - CREATE: Nur das eigene Dokument (uid == request.auth.uid). Status muss
    //    'pending' sein und `locked` darf nicht true sein — Admin-Approval ist
    //    der einzige Weg von 'pending' → 'approved'.
    //  - UPDATE: Admins dürfen alles. Self-Updates nur auf eine fixe Whitelist
    //    von unkritischen Profil-Feldern (lastSeen-Heartbeat, Anzeigename,
    //    mustChangePassword-Flag). Insbesondere `role`, `status`, `permissions`,
    //    `locked`, `additionalRoles`, `canEditPlanung`, `email`, `arbeitszeit`
    //    bleiben Admin-only.
    //  - DELETE: Admin-only.
    //
    // Hinweis: Der bestehende Auto-Lock nach zu vielen Fehlversuchen
    // (lockUserByEmail in AuthContext.tsx) läuft VOR erfolgreichem Login,
    // hat also keinen Auth-Token — er ist hier wie zuvor blockiert.
    match /users/{uid} {
      allow read: if true;

      // Fest geschuetzte Konten (System-Admin + Praxisinhaber): CREATE ueber
      // Client-SDKs IMMER verboten, auch fuer Admins — bewusst OHNE
      // isAdmin()-Ausnahme. Grund (2026-07-10, nach mehreren Reset-
      // Vorfaellen): eine erste Version dieser Regel erlaubte weiterhin
      // isAdmin() als Bypass — da genau diese beiden Konten selbst admin
      // sind, hat isAdmin() (liest die eigene, zum Auswertungszeitpunkt noch
      // admin-Rolle) den Self-Heal-Create trotzdem durchgelassen und das
      // Konto erneut ueberschrieben, nur 38s nach Deployment dieser Regel.
      // Ein (Wieder-)Anlegen dieser beiden Dokumente ist nur noch per
      // Admin-SDK-Skript moeglich (bypasst Rules komplett) — kein Pfad mehr
      // ueber die Client-App, weder Self-Heal noch UserManagementPage.
      allow create: if uid in ['cO1L08kjXlfOnS0KaYUSC0wzSX32', 'ZYC9Yje1C0aoitazRoaVJDKuRM73']
        ? false
        : (isAdmin()
            || (request.auth != null
                && request.auth.uid == uid
                && request.resource.data.status == 'pending'
                && request.resource.data.get('locked', false) != true));

      allow update: if isAdmin()
        || (request.auth != null
            && request.auth.uid == uid
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly([
                    'lastSeen', 'lastLogin',
                    'username', 'displayName', 'mustChangePassword', 'funktion',
                    // E-Mail ist nur Kontakt/Anzeige; Login laeuft ueber Username
                    // und intern ueber `authEmail`. authEmail wird beim Login per
                    // Self-Heal aus auth.currentUser.email nachgefuehrt und ist
                    // damit immer == der echten Firebase-Auth-Identitaet.
                    'email', 'authEmail',
                    // Flag wird vom Self-Heal automatisch abgeraeumt sobald
                    // die Auth-Mail nach echter Adresse aussieht.
                    'mustSetRealEmail'
                  ]));

      // Fest geschuetzte Konten (System-Admin + Praxisinhaber) koennen NIE
      // ueber die Client-SDKs geloescht werden — unabhaengig von ihrer
      // aktuellen Rolle (z.B. nach einer Profil-Selbstheilung auf 'gast').
      allow delete: if isAdmin()
        && !(uid in ['cO1L08kjXlfOnS0KaYUSC0wzSX32', 'ZYC9Yje1C0aoitazRoaVJDKuRM73']);
    }

    // app_versions: Electron-Desktop-App meldet bei jedem Start ihre
    // Versionsnummer — hilft nachzuvollziehen, welcher PC auf welcher
    // Version haengt (Ursache vergangener Liris-Upload-Fehler durch
    // veraltete Versionen). Nur self-write, Staff darf alle lesen.
    match /app_versions/{uid} {
      allow read: if isStaff();
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // sekretariatChats: Besucher-Isolation
    // - Besucher (anonym) sehen + bearbeiten NUR ihre eigene Konversation
    // - Conversation-ID == visitorUid (verhindert Spoofing)
    // - Staff sieht alles
    match /sekretariatChats/{conversationId} {
      allow read: if isStaff()
        || (request.auth != null && resource.data.visitorUid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.visitorUid == request.auth.uid
        && conversationId == request.auth.uid
        && request.resource.data.keys().hasOnly([
            'visitorUid','visitorName','visitorPhone','status',
            'createdAt','lastMessageAt','lastMessagePreview',
            'unreadByStaff','unreadByVisitor',
            'assignedToUid','assignedToName','assignedAt'
           ])
        && request.resource.data.visitorName is string
        && request.resource.data.visitorName.size() <= 100
        && request.resource.data.status == 'open';
      allow update: if isStaff()
        || (request.auth != null && resource.data.visitorUid == request.auth.uid);
      allow delete: if isStaff();

      match /messages/{messageId} {
        allow read: if isStaff()
          || (request.auth != null
              && get(/databases/$(database)/documents/sekretariatChats/$(conversationId)).data.visitorUid == request.auth.uid);
        allow create: if (
            isStaff()
            && request.resource.data.sender == 'staff'
          ) || (
            request.auth != null
            && get(/databases/$(database)/documents/sekretariatChats/$(conversationId)).data.visitorUid == request.auth.uid
            && request.resource.data.sender == 'visitor'
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 2000
          );
        allow update, delete: if isStaff();
      }
    }

    // alle anderen Collections: nur für freigeschaltete Mitarbeiter
    //
    // WICHTIG: `users/**` bewusst ausgeschlossen (2026-07-10, root cause der
    // wiederholten Account-Resets gefunden). Firestore verknuepft ALLE
    // passenden match-Bloecke mit ODER — dieser Catch-All gewaehrte JEDEM
    // Staff-Mitglied (ueber isStaff(), nicht nur Admins) pauschalen
    // read/write-Zugriff auf JEDES Dokument, auch auf users/{uid}. Das hat
    // die gezielten Einschraenkungen im users/{uid}-Block (u.a. das
    // Create-Verbot fuer die geschuetzten UIDs, die Feld-Beschraenkung bei
    // update) komplett unterlaufen — unabhaengig davon was dort verboten
    // war, hat DIESE Regel es trotzdem erlaubt. users/** hat oben bereits
    // eigene, vollstaendige Regeln — braucht den Catch-All nicht.
    match /{collection}/{document=**} {
      allow read, write: if isStaff() && collection != 'users';
    }
  }
}
