rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: ist der eingeloggte User ein freigeschalteter Mitarbeiter?
    // Wird benötigt seit anonyme Besucher (Sekretariat-Chat-Widget) sich
    // ebenfalls bei Firebase Auth anmelden — die dürfen NICHT auf andere
    // Collections zugreifen.
    function isStaff() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('locked', false) != true;
    }

    // passwordResetRequests: jeder darf erstellen (ohne Login), nur Staff liest/ändert
    match /passwordResetRequests/{id} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }

    // adminMessages: unauthentifizierte Benutzer dürfen erstellen (Login-Seite Kontaktformular)
    match /adminMessages/{id} {
      allow create: if
        request.resource.data.keys().hasOnly(['topic', 'senderName', 'email', 'note', 'status', 'createdAt']) &&
        request.resource.data.topic in ['login', 'other'] &&
        request.resource.data.status == 'pending' &&
        (request.resource.data.senderName is string && request.resource.data.senderName.size() <= 100) &&
        (request.resource.data.note is string && request.resource.data.note.size() <= 500);
      allow read, update, delete: if isStaff();
    }

    // users: lesbar ohne Login (für Username-Lookup beim Login & Passwort-Reset)
    // schreibbar nur für eingeloggte Benutzer (eigene Registrierung etc.)
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // sekretariatChats: Besucher-Isolation
    // - Besucher (anonym) sehen + bearbeiten NUR ihre eigene Konversation
    // - Conversation-ID == visitorUid (verhindert Spoofing)
    // - Staff sieht alles
    match /sekretariatChats/{conversationId} {
      allow read: if isStaff()
        || (request.auth != null && resource.data.visitorUid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.visitorUid == request.auth.uid
        && conversationId == request.auth.uid
        && request.resource.data.keys().hasOnly([
            'visitorUid','visitorName','visitorPhone','status',
            'createdAt','lastMessageAt','lastMessagePreview',
            'unreadByStaff','unreadByVisitor',
            'assignedToUid','assignedToName','assignedAt'
           ])
        && request.resource.data.visitorName is string
        && request.resource.data.visitorName.size() <= 100
        && request.resource.data.status == 'open';
      allow update: if isStaff()
        || (request.auth != null && resource.data.visitorUid == request.auth.uid);
      allow delete: if isStaff();

      match /messages/{messageId} {
        allow read: if isStaff()
          || (request.auth != null
              && get(/databases/$(database)/documents/sekretariatChats/$(conversationId)).data.visitorUid == request.auth.uid);
        allow create: if (
            isStaff()
            && request.resource.data.sender == 'staff'
          ) || (
            request.auth != null
            && get(/databases/$(database)/documents/sekretariatChats/$(conversationId)).data.visitorUid == request.auth.uid
            && request.resource.data.sender == 'visitor'
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 2000
          );
        allow update, delete: if isStaff();
      }
    }

    // alle anderen Collections: nur für freigeschaltete Mitarbeiter
    match /{document=**} {
      allow read, write: if isStaff();
    }
  }
}
