rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /documents/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /task-attachments/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /articles/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /onboarding-images/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /notices/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
